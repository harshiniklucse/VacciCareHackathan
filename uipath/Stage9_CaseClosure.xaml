<?xml version="1.0" encoding="utf-8"?>
<!--
  Stage 9 — Case Closure & Certificate Generation
  POST /generate → ReportLab bilingual PDF certificate with ABHA QR code.
  Returns CertPath (download URL) and TotalDoses.

  HTTP: Func(Of String) / System.Net.Http.HttpClient (.NET 8 BCL).
  Log strings: XML attribute delimited with ' so VB string literals use " correctly.
  OutArgument: [varname] VB expression (NOT {x:Reference}).
-->
<Activity mc:Ignorable="sap sap2010"
    x:Class="VacciCare_Maestro.Stage9_CaseClosure"
    xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mva="clr-namespace:Microsoft.VisualBasic.Activities;assembly=System.Activities"
    xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
    xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <x:Members>
    <x:Property Name="in_CaseID"       Type="InArgument(x:String)"  />
    <x:Property Name="in_ChildName"    Type="InArgument(x:String)"  />
    <x:Property Name="in_DOB"          Type="InArgument(x:String)"  />
    <x:Property Name="in_ParentName"   Type="InArgument(x:String)"  />
    <x:Property Name="in_ClinicName"   Type="InArgument(x:String)"  />
    <x:Property Name="in_District"     Type="InArgument(x:String)"  />
    <x:Property Name="in_AbhaID"       Type="InArgument(x:String)"  />
    <x:Property Name="in_VaccinesJSON" Type="InArgument(x:String)"  />
    <x:Property Name="out_CertPath"    Type="OutArgument(x:String)" />
    <x:Property Name="out_TotalDoses"  Type="OutArgument(x:Int32)"  />
  </x:Members>

  <mva:VisualBasic.Settings>Assembly references and imported namespaces serialized as XML namespaces</mva:VisualBasic.Settings>

  <Sequence DisplayName="Stage 9 — Case Closure and Certificate">
    <Sequence.Variables>
      <Variable x:TypeArguments="x:String" Name="v_ServiceUrl"   Default='"https://vaccicarehackathan-production.up.railway.app/generate"' />
      <Variable x:TypeArguments="x:String" Name="v_VaccinesJSON" Default='"[]"' />
      <Variable x:TypeArguments="x:String" Name="v_RequestBody"  Default='""' />
      <Variable x:TypeArguments="x:String" Name="v_ResponseBody" Default='""' />
      <Variable x:TypeArguments="x:String" Name="v_CertPath"     Default='""' />
      <Variable x:TypeArguments="x:Int32"  Name="v_TotalDoses"   Default="0" />
    </Sequence.Variables>

    <WriteLine DisplayName="[Log] Stage 9 starting"
        Text='["[Stage9] Generating certificate for case: " + in_CaseID]' />

    <!-- STEP 1: Normalise vaccines array — default [] if caller passes nothing -->
    <Assign DisplayName="S9 Normalise vaccines">
      <Assign.To>
        <OutArgument x:TypeArguments="x:String">[v_VaccinesJSON]</OutArgument>
      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">
          [If(String.IsNullOrWhiteSpace(in_VaccinesJSON), "[]", in_VaccinesJSON)]
        </InArgument>
      </Assign.Value>
    </Assign>

    <!-- STEP 2: Build certificate request JSON
         {7} is v_VaccinesJSON — a raw JSON array, no quotes around it -->
    <Assign DisplayName="S9 Build request body">
      <Assign.To>
        <OutArgument x:TypeArguments="x:String">[v_RequestBody]</OutArgument>
      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">
          [String.Format("{{""child_id"":""{0}"",""child_name"":""{1}"",""dob"":""{2}"",""parent_name"":""{3}"",""clinic_name"":""{4}"",""district"":""{5}"",""abha_id"":""{6}"",""vaccines"":{7}}}",
            in_CaseID, in_ChildName, in_DOB, in_ParentName,
            in_ClinicName, in_District,
            If(String.IsNullOrWhiteSpace(in_AbhaID), "NOT-REGISTERED", in_AbhaID),
            v_VaccinesJSON)]
        </InArgument>
      </Assign.Value>
    </Assign>

    <!-- STEP 3: HTTP POST -->
    <Assign DisplayName="S9 POST /generate">
      <Assign.To>
        <OutArgument x:TypeArguments="x:String">[v_ResponseBody]</OutArgument>
      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">
[(New Func(Of String)(Function()
    Dim hc As New System.Net.Http.HttpClient()
    Dim ct As New System.Net.Http.StringContent(v_RequestBody, System.Text.Encoding.UTF8, "application/json")
    Try
        Return hc.PostAsync(v_ServiceUrl, ct).GetAwaiter().GetResult().Content.ReadAsStringAsync().GetAwaiter().GetResult()
    Catch ex As Exception
        Return "{""error"":true,""msg"":""" + ex.Message.Replace("""","'") + """}"
    Finally
        hc.Dispose()
    End Try
End Function)).Invoke()]
        </InArgument>
      </Assign.Value>
    </Assign>

    <!-- STEP 4: Parse response -->
    <If DisplayName="S9 Parse response">
      <If.Condition>
        <InArgument x:TypeArguments="x:Boolean">
          [Newtonsoft.Json.Linq.JObject.Parse(v_ResponseBody)("CertPath") IsNot Nothing]
        </InArgument>
      </If.Condition>
      <If.Then>
        <Sequence DisplayName="S9 Extract fields">
          <Assign DisplayName="S9 Extract CertPath">
            <Assign.To><OutArgument x:TypeArguments="x:String">[v_CertPath]</OutArgument></Assign.To>
            <Assign.Value>
              <InArgument x:TypeArguments="x:String">
                [Newtonsoft.Json.Linq.JObject.Parse(v_ResponseBody)("CertPath").ToString()]
              </InArgument>
            </Assign.Value>
          </Assign>
          <Assign DisplayName="S9 Extract TotalDoses">
            <Assign.To><OutArgument x:TypeArguments="x:Int32">[v_TotalDoses]</OutArgument></Assign.To>
            <Assign.Value>
              <InArgument x:TypeArguments="x:Int32">
                [If(Newtonsoft.Json.Linq.JObject.Parse(v_ResponseBody)("TotalDoses") IsNot Nothing, Integer.Parse(Newtonsoft.Json.Linq.JObject.Parse(v_ResponseBody)("TotalDoses").ToString()), 0)]
              </InArgument>
            </Assign.Value>
          </Assign>
          <WriteLine DisplayName="[Log] S9 success"
              Text='["[Stage9] Certificate: " + v_CertPath + " Doses: " + v_TotalDoses.ToString()]' />
        </Sequence>
      </If.Then>
      <If.Else>
        <WriteLine DisplayName="[Log] S9 error"
            Text='["[Stage9] ERROR: " + v_ResponseBody]' />
      </If.Else>
    </If>

    <!-- STEP 5: Copy locals to output arguments -->
    <Assign DisplayName="Set out_CertPath">
      <Assign.To><OutArgument x:TypeArguments="x:String">[out_CertPath]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[v_CertPath]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Set out_TotalDoses">
      <Assign.To><OutArgument x:TypeArguments="x:Int32">[out_TotalDoses]</OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:Int32">[v_TotalDoses]</InArgument></Assign.Value>
    </Assign>

    <WriteLine DisplayName="[Log] Case closed"
        Text='["[Stage9] CASE CLOSED: " + in_CaseID + " Certificate: " + v_CertPath]' />

  </Sequence>
</Activity>
