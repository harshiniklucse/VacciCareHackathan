<?xml version="1.0" encoding="utf-8"?>
<Activity mc:Ignorable="sap sap2010"
    x:Class="VacciCare_Maestro.Main"
    xmlns="http://schemas.microsoft.com/netfx/2009/xaml/activities"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:mva="clr-namespace:Microsoft.VisualBasic.Activities;assembly=System.Activities"
    xmlns:sap="http://schemas.microsoft.com/netfx/2009/xaml/activities/presentation"
    xmlns:sap2010="http://schemas.microsoft.com/netfx/2010/xaml/activities/presentation"
    xmlns:webapi="clr-namespace:UiPath.WebAPI.Activities;assembly=UiPath.WebAPI.Activities"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- ═══════════════════════════════════════════════════════════════════
       VacciCare Maestro — Main Entry Point
       Runs all 4 case stages in sequence:
         Stage 2  →  POST /schedule    (IAP vaccine schedule)
         Stage 3  →  POST /compose     (DLT WhatsApp reminder)
         Stage 7  →  POST /score       (dropout risk)
         Stage 9  →  POST /generate    (bilingual PDF certificate)
       All HTTP calls go to the combined Railway service.
       ═══════════════════════════════════════════════════════════════════ -->

  <x:Members>
    <!-- ── Inputs from Maestro case ─────────────────────────────────── -->
    <x:Property Name="in_CaseID"         Type="InArgument(x:String)" />
    <x:Property Name="in_ChildName"      Type="InArgument(x:String)" />
    <x:Property Name="in_ChildDOB"       Type="InArgument(x:String)" />
    <x:Property Name="in_ParentName"     Type="InArgument(x:String)" />
    <x:Property Name="in_Language"       Type="InArgument(x:String)" />
    <x:Property Name="in_ClinicName"     Type="InArgument(x:String)" />
    <x:Property Name="in_ClinicAddress"  Type="InArgument(x:String)" />
    <x:Property Name="in_District"       Type="InArgument(x:String)" />
    <!-- ── Outputs back to Maestro ───────────────────────────────────── -->
    <x:Property Name="out_NextVaccine"   Type="OutArgument(x:String)" />
    <x:Property Name="out_NextDueDate"   Type="OutArgument(x:String)" />
    <x:Property Name="out_MessageBody"   Type="OutArgument(x:String)" />
    <x:Property Name="out_DLTTemplate"   Type="OutArgument(x:String)" />
    <x:Property Name="out_RiskScore"     Type="OutArgument(x:Double)" />
    <x:Property Name="out_RiskLabel"     Type="OutArgument(x:String)" />
    <x:Property Name="out_EscalateNow"   Type="OutArgument(x:Boolean)" />
    <x:Property Name="out_CertPath"      Type="OutArgument(x:String)" />
  </x:Members>

  <mva:VisualBasic.Settings>Assembly references and imported namespaces serialized as XML namespaces</mva:VisualBasic.Settings>

  <Sequence DisplayName="VacciCare Maestro — Full Case Run">
    <Sequence.Variables>
      <Variable x:TypeArguments="x:String"  Name="v_Base"         Default='"https://vaccicarehackathan-production.up.railway.app"' />
      <Variable x:TypeArguments="x:String"  Name="v_RequestBody"  Default='""' />
      <Variable x:TypeArguments="x:String"  Name="v_ResponseBody" Default='""' />
      <Variable x:TypeArguments="x:Int32"   Name="v_Status"       Default="0" />
      <!-- Stage 2 working vars -->
      <Variable x:TypeArguments="x:String"  Name="v_NextVaccine"  Default='""' />
      <Variable x:TypeArguments="x:String"  Name="v_NextDueDate"  Default='""' />
      <!-- Stage 3 working vars -->
      <Variable x:TypeArguments="x:String"  Name="v_MessageBody"  Default='""' />
      <Variable x:TypeArguments="x:String"  Name="v_DLTTemplate"  Default='""' />
      <!-- Stage 7 working vars -->
      <Variable x:TypeArguments="x:Double"  Name="v_RiskScore"    Default="0.0" />
      <Variable x:TypeArguments="x:String"  Name="v_RiskLabel"    Default='"LOW"' />
      <Variable x:TypeArguments="x:Boolean" Name="v_EscalateNow"  Default="False" />
      <!-- Stage 9 working vars -->
      <Variable x:TypeArguments="x:String"  Name="v_CertPath"     Default='""' />
    </Sequence.Variables>

    <WriteLine DisplayName="[Log] VacciCare starting"
        Text="['[VacciCare] ════ Case: ' + in_CaseID + ' | Child: ' + in_ChildName + ' | DOB: ' + in_ChildDOB + ' ════']" />


    <!-- ══════════════════════════════════════════════════════════
         STAGE 2 — Schedule Planning  (POST /schedule)
         ══════════════════════════════════════════════════════════ -->
    <Assign DisplayName="S2: Build request body">
      <Assign.To>
        <OutArgument x:TypeArguments="x:String">
          <VariableReference x:TypeArguments="x:String" Variable="{x:Reference v_RequestBody}" />
        </OutArgument>
      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">
          [String.Format("{{""child_id"":""{0}"",""dob"":""{1}"",""birth_weight_grams"":2500,""gestation_weeks"":40}}", in_CaseID, in_ChildDOB)]
        </InArgument>
      </Assign.Value>
    </Assign>

    <webapi:HTTPRequest DisplayName="S2: POST /schedule"
        EndPoint="[v_Base + &quot;/schedule&quot;]"
        Method="Post"
        Body="[v_RequestBody]"
        BodyFormat="application/json"
        AcceptedMediaType="application/json"
        ResponseContent="[v_ResponseBody]"
        StatusCode="[v_Status]" />

    <If DisplayName="S2: Parse response">
      <If.Condition>
        <InArgument x:TypeArguments="x:Boolean">[v_Status >= 200 AndAlso v_Status &lt;= 299]</InArgument>
      </If.Condition>
      <If.Then>
        <Sequence DisplayName="S2: Extract fields">
          <Assign DisplayName="S2: NextVaccine">
            <Assign.To><OutArgument x:TypeArguments="x:String"><VariableReference x:TypeArguments="x:String" Variable="{x:Reference v_NextVaccine}" /></OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:String">
              [If(Newtonsoft.Json.Linq.JObject.Parse(v_ResponseBody)("NextDueVaccine") IsNot Nothing,
                 Newtonsoft.Json.Linq.JObject.Parse(v_ResponseBody)("NextDueVaccine").ToString(),
                 "All doses complete")]
            </InArgument></Assign.Value>
          </Assign>
          <Assign DisplayName="S2: NextDueDate">
            <Assign.To><OutArgument x:TypeArguments="x:String"><VariableReference x:TypeArguments="x:String" Variable="{x:Reference v_NextDueDate}" /></OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:String">
              [If(Newtonsoft.Json.Linq.JObject.Parse(v_ResponseBody)("NextDueDate") IsNot Nothing,
                 Newtonsoft.Json.Linq.JObject.Parse(v_ResponseBody)("NextDueDate").ToString(),
                 "")]
            </InArgument></Assign.Value>
          </Assign>
          <WriteLine Text="['[Stage2] ✓ Next vaccine: ' + v_NextVaccine + ' | Due: ' + v_NextDueDate]" />
        </Sequence>
      </If.Then>
      <If.Else>
        <WriteLine Text="['[Stage2] ✗ HTTP ' + v_Status.ToString() + ' — ' + v_ResponseBody]" />
      </If.Else>
    </If>


    <!-- ══════════════════════════════════════════════════════════
         STAGE 3 — Reminder Dispatch  (POST /compose)
         ══════════════════════════════════════════════════════════ -->
    <Assign DisplayName="S3: Build request body">
      <Assign.To>
        <OutArgument x:TypeArguments="x:String">
          <VariableReference x:TypeArguments="x:String" Variable="{x:Reference v_RequestBody}" />
        </OutArgument>
      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">
          [String.Format("{{""child_id"":""{0}"",""child_name"":""{1}"",""parent_name"":""{2}"",""vaccine_name"":""{3}"",""due_date"":""{4}"",""clinic_name"":""{5}"",""clinic_address"":""{6}"",""language"":""{7}"",""reminder_number"":1}}",
            in_CaseID, in_ChildName, in_ParentName,
            v_NextVaccine, v_NextDueDate,
            in_ClinicName, in_ClinicAddress,
            If(String.IsNullOrWhiteSpace(in_Language), "en", in_Language.ToLower().Trim()))]
        </InArgument>
      </Assign.Value>
    </Assign>

    <webapi:HTTPRequest DisplayName="S3: POST /compose"
        EndPoint="[v_Base + &quot;/compose&quot;]"
        Method="Post"
        Body="[v_RequestBody]"
        BodyFormat="application/json"
        AcceptedMediaType="application/json"
        ResponseContent="[v_ResponseBody]"
        StatusCode="[v_Status]" />

    <If DisplayName="S3: Parse response">
      <If.Condition>
        <InArgument x:TypeArguments="x:Boolean">[v_Status >= 200 AndAlso v_Status &lt;= 299]</InArgument>
      </If.Condition>
      <If.Then>
        <Sequence DisplayName="S3: Extract fields">
          <Assign DisplayName="S3: MessageBody">
            <Assign.To><OutArgument x:TypeArguments="x:String"><VariableReference x:TypeArguments="x:String" Variable="{x:Reference v_MessageBody}" /></OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:String">
              [Newtonsoft.Json.Linq.JObject.Parse(v_ResponseBody)("MessageBody").ToString()]
            </InArgument></Assign.Value>
          </Assign>
          <Assign DisplayName="S3: DLTTemplate">
            <Assign.To><OutArgument x:TypeArguments="x:String"><VariableReference x:TypeArguments="x:String" Variable="{x:Reference v_DLTTemplate}" /></OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:String">
              [Newtonsoft.Json.Linq.JObject.Parse(v_ResponseBody)("DLTTemplateID").ToString()]
            </InArgument></Assign.Value>
          </Assign>
          <WriteLine Text="['[Stage3] ✓ DLT: ' + v_DLTTemplate + ' | Msg: ' + v_MessageBody.Substring(0, Math.Min(60, v_MessageBody.Length)) + '...']" />
        </Sequence>
      </If.Then>
      <If.Else>
        <WriteLine Text="['[Stage3] ✗ HTTP ' + v_Status.ToString() + ' — ' + v_ResponseBody]" />
      </If.Else>
    </If>


    <!-- ══════════════════════════════════════════════════════════
         STAGE 7 — Risk Scoring  (POST /score)
         ══════════════════════════════════════════════════════════ -->
    <Assign DisplayName="S7: Build request body">
      <Assign.To>
        <OutArgument x:TypeArguments="x:String">
          <VariableReference x:TypeArguments="x:String" Variable="{x:Reference v_RequestBody}" />
        </OutArgument>
      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">
          [String.Format("{{""child_id"":""{0}"",""no_show_count"":0,""reminders_sent"":1,""distance_km"":5.0,""prev_missed_doses"":0,""is_migrated"":false,""mother_age_under_20"":false,""rural_flag"":false}}",
            in_CaseID)]
        </InArgument>
      </Assign.Value>
    </Assign>

    <webapi:HTTPRequest DisplayName="S7: POST /score"
        EndPoint="[v_Base + &quot;/score&quot;]"
        Method="Post"
        Body="[v_RequestBody]"
        BodyFormat="application/json"
        AcceptedMediaType="application/json"
        ResponseContent="[v_ResponseBody]"
        StatusCode="[v_Status]" />

    <If DisplayName="S7: Parse response">
      <If.Condition>
        <InArgument x:TypeArguments="x:Boolean">[v_Status >= 200 AndAlso v_Status &lt;= 299]</InArgument>
      </If.Condition>
      <If.Then>
        <Sequence DisplayName="S7: Extract fields">
          <Assign DisplayName="S7: RiskScore">
            <Assign.To><OutArgument x:TypeArguments="x:Double"><VariableReference x:TypeArguments="x:Double" Variable="{x:Reference v_RiskScore}" /></OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:Double">
              [Double.Parse(Newtonsoft.Json.Linq.JObject.Parse(v_ResponseBody)("RiskScore").ToString())]
            </InArgument></Assign.Value>
          </Assign>
          <Assign DisplayName="S7: RiskLabel">
            <Assign.To><OutArgument x:TypeArguments="x:String"><VariableReference x:TypeArguments="x:String" Variable="{x:Reference v_RiskLabel}" /></OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:String">
              [Newtonsoft.Json.Linq.JObject.Parse(v_ResponseBody)("RiskLabel").ToString()]
            </InArgument></Assign.Value>
          </Assign>
          <Assign DisplayName="S7: EscalateNow">
            <Assign.To><OutArgument x:TypeArguments="x:Boolean"><VariableReference x:TypeArguments="x:Boolean" Variable="{x:Reference v_EscalateNow}" /></OutArgument></Assign.To>
            <Assign.Value><InArgument x:TypeArguments="x:Boolean">
              [Boolean.Parse(Newtonsoft.Json.Linq.JObject.Parse(v_ResponseBody)("EscalateImmediately").ToString())]
            </InArgument></Assign.Value>
          </Assign>
          <WriteLine Text="['[Stage7] ✓ Risk: ' + v_RiskLabel + ' (' + v_RiskScore.ToString(&quot;F2&quot;) + ') | Escalate: ' + v_EscalateNow.ToString()]" />
        </Sequence>
      </If.Then>
      <If.Else>
        <WriteLine Text="['[Stage7] ✗ HTTP ' + v_Status.ToString() + ' — ' + v_ResponseBody]" />
      </If.Else>
    </If>


    <!-- ══════════════════════════════════════════════════════════
         STAGE 9 — Case Closure / Certificate  (POST /generate)
         ══════════════════════════════════════════════════════════ -->
    <Assign DisplayName="S9: Build request body">
      <Assign.To>
        <OutArgument x:TypeArguments="x:String">
          <VariableReference x:TypeArguments="x:String" Variable="{x:Reference v_RequestBody}" />
        </OutArgument>
      </Assign.To>
      <Assign.Value>
        <InArgument x:TypeArguments="x:String">
          [String.Format("{{""child_id"":""{0}"",""child_name"":""{1}"",""dob"":""{2}"",""parent_name"":""{3}"",""clinic_name"":""{4}"",""district"":""{5}"",""abha_id"":""NOT-REGISTERED"",""vaccines"":[]}}",
            in_CaseID, in_ChildName, in_ChildDOB, in_ParentName, in_ClinicName, in_District)]
        </InArgument>
      </Assign.Value>
    </Assign>

    <webapi:HTTPRequest DisplayName="S9: POST /generate"
        EndPoint="[v_Base + &quot;/generate&quot;]"
        Method="Post"
        Body="[v_RequestBody]"
        BodyFormat="application/json"
        AcceptedMediaType="application/json"
        ResponseContent="[v_ResponseBody]"
        StatusCode="[v_Status]" />

    <If DisplayName="S9: Parse response">
      <If.Condition>
        <InArgument x:TypeArguments="x:Boolean">[v_Status >= 200 AndAlso v_Status &lt;= 299]</InArgument>
      </If.Condition>
      <If.Then>
        <Assign DisplayName="S9: CertPath">
          <Assign.To><OutArgument x:TypeArguments="x:String"><VariableReference x:TypeArguments="x:String" Variable="{x:Reference v_CertPath}" /></OutArgument></Assign.To>
          <Assign.Value><InArgument x:TypeArguments="x:String">
            [Newtonsoft.Json.Linq.JObject.Parse(v_ResponseBody)("CertPath").ToString()]
          </InArgument></Assign.Value>
        </Assign>
      </If.Then>
      <If.Else>
        <WriteLine Text="['[Stage9] ✗ HTTP ' + v_Status.ToString() + ' — ' + v_ResponseBody]" />
      </If.Else>
    </If>

    <WriteLine DisplayName="[Log] Case complete"
        Text="['[VacciCare] ════ COMPLETE — ' + in_CaseID + ' | Vaccine: ' + v_NextVaccine + ' | Risk: ' + v_RiskLabel + ' | Cert: ' + v_CertPath + ' ════']" />

    <!-- ── Copy working vars to output arguments ─────────────────── -->
    <Assign DisplayName="Set out_NextVaccine">
      <Assign.To><OutArgument x:TypeArguments="x:String"><ArgumentReference x:TypeArguments="x:String" ArgumentName="out_NextVaccine" /></OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[v_NextVaccine]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Set out_NextDueDate">
      <Assign.To><OutArgument x:TypeArguments="x:String"><ArgumentReference x:TypeArguments="x:String" ArgumentName="out_NextDueDate" /></OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[v_NextDueDate]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Set out_MessageBody">
      <Assign.To><OutArgument x:TypeArguments="x:String"><ArgumentReference x:TypeArguments="x:String" ArgumentName="out_MessageBody" /></OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[v_MessageBody]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Set out_DLTTemplate">
      <Assign.To><OutArgument x:TypeArguments="x:String"><ArgumentReference x:TypeArguments="x:String" ArgumentName="out_DLTTemplate" /></OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[v_DLTTemplate]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Set out_RiskScore">
      <Assign.To><OutArgument x:TypeArguments="x:Double"><ArgumentReference x:TypeArguments="x:Double" ArgumentName="out_RiskScore" /></OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:Double">[v_RiskScore]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Set out_RiskLabel">
      <Assign.To><OutArgument x:TypeArguments="x:String"><ArgumentReference x:TypeArguments="x:String" ArgumentName="out_RiskLabel" /></OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[v_RiskLabel]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Set out_EscalateNow">
      <Assign.To><OutArgument x:TypeArguments="x:Boolean"><ArgumentReference x:TypeArguments="x:Boolean" ArgumentName="out_EscalateNow" /></OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:Boolean">[v_EscalateNow]</InArgument></Assign.Value>
    </Assign>
    <Assign DisplayName="Set out_CertPath">
      <Assign.To><OutArgument x:TypeArguments="x:String"><ArgumentReference x:TypeArguments="x:String" ArgumentName="out_CertPath" /></OutArgument></Assign.To>
      <Assign.Value><InArgument x:TypeArguments="x:String">[v_CertPath]</InArgument></Assign.Value>
    </Assign>

  </Sequence>
</Activity>
